        "population_structure": {
          "n_input_only": 60,
          "n_input_readout": 0,
          "n_readout_only": 60,
          "n_recurrent_only": 60
        },
        "sisu_gating": "additive"
      },
      "type": "RLRMPSimpleStagedNetwork"
    },
