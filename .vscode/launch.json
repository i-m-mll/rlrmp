{
    // "type": "python",
    // "request": "launch",
    // "program": "${file}",
    // "console": "integratedTerminal",
    // "cwd": "${fileDirname}",
    // "env": {
    //     "PYTHONPATH": "/home/mll/.miniforge3/envs/rbst/bin/python"
    // },
    "configurations": [
        {
            "name": "Debug: run analysis (batched)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run",
            "args": ["analysis", "--batched", "${input:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
        },
            {
            "name": "Debug: run analysis (single)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run",
            "args": ["analysis", "--single", "${input:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
        },
        {
            "name": "Debug: run train (batched)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run",
            "args": ["train", "--batched", "${input:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
        },
            {
            "name": "Debug: run train (single)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run",
            "args": ["train", "--single", "${input:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            // "python": "/Users/mll/Main/10 Projects/10 PhD/rlrmp/.venv/bin/python",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
        },
        {
            "name": "Debug: run train (batched) + optional extras",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/args_shim.py",
            "args": [
                "train",
                "--batched",
                "${input:expKey}" // optional positional (can be left blank)
            ],
            "env": {
                "EXTRA_ARGS": "${input:extraArgs}" // zero or more extra flags/tokens
            },
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Debug: run analysis (batched) + optional extras",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/args_shim.py",
            "args": [
                "analysis",
                "--batched",
                "${input:expKey}"
            ],
            "env": {
                "EXTRA_ARGS": "${input:extraArgs}"
            },
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Debug: run (with args)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run",
            "args": ["${input:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["${command:pickArgs}"],
            "envFile": "${workspaceFolder}/.env",
            // "preLaunchTask": "activate-conda-env"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "envFile": "${workspaceFolder}/.env",
            // "preLaunchTask": "activate-conda-env"
        }
    ],
    "inputs": [
        {
            "id": "pickArgs",
            "type": "promptString",
            "description": "Arguments to pass to the script",
            "default": ""
        },  
        {
            "id": "extraArgs",
            "type": "promptString",
            "description": "Extra CLI args (optional, space-separated). Example: --force-postprocess --epochs 5",
            "default": ""
        },
        {
            "id": "expKey",
            "type": "promptString",
            "description": "Experiment key / trailing positional (optional)",
            "default": ""
        }
    ]
}