    "configurations": [
        {
            "name": "Debug: run_analysis (batched)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run_analysis",
            "args": ["--batched", "${command:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"
            }
        },
            {
            "name": "Debug: run_analysis (single)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run_analysis",
            "args": ["--single", "${command:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"
            }
        },
        {
            "name": "Debug: run_analysis (with args)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run_analysis",
            "args": ["${command:pickArgs}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"
            }
        },
        {
            "name": "Debug: run_analysis (SVG only)",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbax_experiments.bin.run_analysis",
            "args": ["${command:pickArgs}", "--fig-dump-formats", "svg"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false,
            "env": {
                "PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"
        }
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["${command:pickArgs}"],
            "env": {"PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"},
            // "preLaunchTask": "activate-conda-env"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {"PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT": "2"},
            // "preLaunchTask": "activate-conda-env"
        }
    ]
